# ─── Contact form email (server/index.js) ───────────────────────────
# Copy this file to ".env" and fill in real values. Never commit ".env".

# Where submissions are delivered.
MAIL_TO=abhijeetkumar081037@gmail.com

# SMTP credentials used to SEND the mail.
# Easiest option: a Gmail account with a 16-char App Password
#   1. Enable 2-Step Verification on the Google account
#   2. Google Account → Security → App passwords → generate one
#   3. Put that account's address in SMTP_USER and the app password in SMTP_PASS
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-sender@gmail.com
SMTP_PASS=your-16-char-app-password

# Optional: the "From" header (Gmail requires it to equal SMTP_USER).
MAIL_FROM=your-sender@gmail.com

# Lock the API to your site's origin in production (e.g. https://yoursite.com).
# Use * only for local development.
ALLOWED_ORIGIN=*

# Port the API listens on (the Vite dev proxy expects 3001).
PORT=3001
