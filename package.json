{
  "name": "portfolio",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "node server/index.js",
    "dev:server": "node --watch server/index.js",
    "dev:all": "concurrently -k -n web,api -c cyan,magenta \"npm:dev\" \"npm:dev:server\"",
    "build": "vite build",
    "preview": "vite preview",
    "format": "prettier --write \"src/**/*.{js,jsx,css}\" \"server/**/*.js\" \"*.{html,json}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,css}\" \"server/**/*.js\" \"*.{html,json}\""
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.8",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "framer-motion": "^11.3.0",
    "nodemailer": "^6.9.14",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "prettier": "^3.3.3",
    "vite": "^5.4.0"
  }
}
